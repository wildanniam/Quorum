DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/quorum"
# Optional migration/admin connection. Use Supabase direct URL here if runtime DATABASE_URL is pooled.
DIRECT_DATABASE_URL=""
# Optional server-only schema override for isolated smoke tests or non-public schemas.
QUORUM_DB_SCHEMA="public"

QUORUM_SESSION_SECRET="replace-with-a-long-random-secret"
# Production/hosted deploys must replace QUORUM_SESSION_SECRET with a non-placeholder value of at least 32 characters.
# Required for the hosted Vercel Cron route. Generate at least 32 random characters.
CRON_SECRET=""
QUORUM_INDEXER_START_LEDGER=""
QUORUM_INDEXER_RECENT_LEDGER_WINDOW=""

# Public domain signing key published at /.well-known/stellar.toml for anchor
# client-domain flows. The default route falls back to Quorum's generated
# testnet domain key if this is unset.
ANCHOR_CLIENT_SIGNING_PUBLIC_KEY=""
# Server-only Stellar secret seed for the same client-domain signing key. Required
# only when ANCHOR_PROVIDER=moneygram. Never expose this with NEXT_PUBLIC_.
ANCHOR_CLIENT_SIGNING_SECRET=""
ANCHOR_PROVIDER="mock"
ANCHOR_CLIENT_DOMAIN="quorum-sandy-eight.vercel.app"
MONEYGRAM_HOME_DOMAIN="extstellar.moneygram.com"
MONEYGRAM_TIMEOUT_MS="15000"
MONEYGRAM_USDC_ISSUER="GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5"

NEXT_PUBLIC_STELLAR_NETWORK="TESTNET"
NEXT_PUBLIC_STELLAR_RPC_URL="https://soroban-testnet.stellar.org"
NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
NEXT_PUBLIC_QUORUM_CORE_CONTRACT_ID=""
NEXT_PUBLIC_QUORUM_PASS_CONTRACT_ID=""
NEXT_PUBLIC_STELLAR_USDC_CONTRACT_ID=""

# Supabase is used only as server-side Postgres. Do not add NEXT_PUBLIC_SUPABASE_*.

# Contract deployment scripts and doctor reject any value other than testnet.
STELLAR_NETWORK="testnet"
STELLAR_ACCOUNT=""
# Leave empty until explicit approval for live testnet signing.
QUORUM_LIVE_SIGNING_APPROVED=""
ADMIN_ADDRESS=""
QUORUM_PLATFORM_FEE_BPS="0"
# Leave empty unless product owner explicitly approves a non-zero platform fee.
QUORUM_NONZERO_PLATFORM_FEE_APPROVED=""
